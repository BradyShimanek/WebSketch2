{
    "name": "WebSketch2",
    "description": "WebSketch2 is a tool that allows you to draw on webpages.",
    "version": "1.0",
    "manifest_version": 3,
    "permissions": [
        "activeTab"
    ],
    "action": {
      "default_popup": "popup/popup.html",
      "default_icon": { 
        "16": "icons/pencil2.png", 
        "48": "icons/pencil2.png", 
        "128": "icons/pencil2.png" }
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content/content.js"],
            "css": ["content/content.css"]
        }
    ]
}